{
  "name": "rork-western-credit-app-clone-4-tests",
  "version": "1.0.0",
  "description": "Test configuration for Business Ownership & Customization System",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:business": "jest __tests__/business-ownership.test.ts",
    "test:customization": "jest __tests__/customization.test.ts",
    "test:marketplace": "jest __tests__/marketplace.test.ts",
    "test:initialization": "jest __tests__/business-initialization.test.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write &quot;**/*.{ts,tsx,json,md}&quot;",
    "format:check": "prettier --check &quot;**/*.{ts,tsx,json,md}&quot;"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/__tests__"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "collectCoverageFrom": [
      "services/**/*.ts",
      "types/**/*.ts",
      "!**/node_modules/**",
      "!**/dist/**",
      "!**/.next/**"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}